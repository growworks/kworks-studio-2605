# ─────────────────────────────────────────────
# 사이트 식별자 (admin 명세 §SiteSlug.enum: [kworksstudio] 고정)
# ─────────────────────────────────────────────
SITE_SLUG=kworksstudio

# ─────────────────────────────────────────────
# admin 공개 API
# 운영 베이스. 로컬 admin 띄울 경우 http://localhost:80 으로 교체.
# ─────────────────────────────────────────────
API_BASE_URL=https://api.growworks.co.kr

# 상담신청만 mock 처리 (콘텐츠 fetch 는 mock 없음 — admin 필수)
# 운영에서는 false, 로컬에서는 admin 상담신청까지 가지 않게 true 사용 권장.
CONTACT_API_MOCK=false

# ─────────────────────────────────────────────
# SEO / 분석 (선택)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://k-worksstudio.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
